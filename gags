local function CreateConfigToggle(labelText, configKey, parent)
    local defaultState = getgenv().Config[configKey]
    local btn = CreateButton(
        defaultState and ("🟢 " .. labelText .. ": ON") or ("🔴 " .. labelText .. ": OFF"),
        defaultState and Color3.fromRGB(40, 110, 60) or Color3.fromRGB(90, 40, 40),
        parent, nil
    )
    btn.MouseButton1Click:Connect(function()
        getgenv().Config[configKey] = not getgenv().Config[configKey]
        if getgenv().Config[configKey] then
            btn.Text = "🟢 " .. labelText .. ": ON"; btn.BackgroundColor3 = Color3.fromRGB(40, 110, 60)
        else
            btn.Text = "🔴 " .. labelText .. ": OFF"; btn.BackgroundColor3 = Color3.fromRGB(90, 40, 40)
        end
    end)
    return btn
end

