    TitleLabel.TextColor3 = Color3.fromRGB(180, 185, 200)
    TitleLabel.TextSize = 12
    TitleLabel.TextXAlignment = Enum.TextXAlignment.Left
    
    local inp = CreateInput("Type here...", parent, function(val)
        if isTable then
            local t = {}
            for s in string.gmatch(val, "([^,;|]+)") do table.insert(t, string.match(s, "^%s*(.-)%s*$")) end
            if val == "" then t = {""} end
            getgenv().Config[configKey] = t
        else
            getgenv().Config[configKey] = tostring(val)
        end
    end)
    
    local default = getgenv().Config[configKey]
    inp.Text = type(default) == "table" and table.concat(default, ", ") or tostring(default)
    return inp
end

