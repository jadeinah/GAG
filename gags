local function sanitize_string(str)
    return string.lower(string.gsub(tostring(str), "[%s_]", ""))
end

local function unequip_pets_on_start()
    API:FindFirstChild("ToolAPI/Unequip"):InvokeServer(LocalPlayer.Character, "Pet")
end

local function equip_pet(pet_unique)
    API:FindFirstChild("ToolAPI/Equip"):InvokeServer(pet_unique)
end

local function get_pet_remote_name(display_name)
    local target = sanitize_string(display_name)
    local partial_match = nil
    
    for _, z in pairs(ReplicatedStorage.SharedModules.ContentPacks:GetChildren()) do
        if z:IsA("Folder") and z:FindFirstChild("InventorySubDB") and z.InventorySubDB:FindFirstChild("Pets") then
            for _, Pet in pairs(require(z.InventorySubDB.Pets)) do
                local clean_internal = sanitize_string(Pet.kind)
                if clean_internal == target then return Pet.kind end
                if not partial_match and string.find(clean_internal, target, 1, true) then partial_match = Pet.kind end
            end
        end
    end
    return partial_match
end

local function find_all_basic_pets_uniques(pet_remote_name, how_much_pets_needed)
    local pets_array = {}
    local target_name = string.lower(tostring(pet_remote_name)) 
    for _, v in pairs(require(ReplicatedStorage.ClientModules.Core.ClientData).get_data()[tostring(LocalPlayer)].inventory.pets) do
        if string.lower(tostring(v.kind)) == target_name and tonumber(v.properties.age or 0) < 6 and not v.properties.neon and not v.properties.mega_neon then
            if #pets_array == tonumber(how_much_pets_needed) then break else table.insert(pets_array, v.unique) end
        end
    end
    return pets_array
end

local function find_all_neons_pets_uniques(pet_remote_name, how_much_pets_needed)
    local pets_array = {}
    local target_name = string.lower(tostring(pet_remote_name)) 
    for _, v in pairs(require(ReplicatedStorage.ClientModules.Core.ClientData).get_data()[tostring(LocalPlayer)].inventory.pets) do
        if string.lower(tostring(v.kind)) == target_name and tonumber(v.properties.age or 0) < 6 and v.properties.neon and not v.properties.mega_neon then
            if #pets_array == tonumber(how_much_pets_needed) then break else table.insert(pets_array, v.unique) end
        end
    end
    return pets_array
end

local function get_needed_quantity_of_potions(pet_remote_name)
    local rarity = ""
    local target_name = string.lower(tostring(pet_remote_name)) 
    for _, z in pairs(ReplicatedStorage.SharedModules.ContentPacks:GetChildren()) do
        if z:IsA("Folder") and z:FindFirstChild("InventorySubDB") and z.InventorySubDB:FindFirstChild("Pets") then
            for _, Pet in pairs(require(z.InventorySubDB.Pets)) do
                if string.lower(tostring(Pet.kind)) == target_name then rarity = Pet.rarity break end
            end
        end
    end
    local rarityMap = {common = 1, uncommon = 2, rare = 2, ultra_rare = 4, legendary = 7}
    return rarityMap[rarity] or 1
end

local function find_and_prepare_all_needed_potions(quantity)
    local potions_uniques_array = {}
    for _, item in pairs(require(ReplicatedStorage.ClientModules.Core.ClientData).get_data()[tostring(LocalPlayer)].inventory.food) do
        if item.kind == "pet_age_potion" then
            if #potions_uniques_array == tonumber(quantity) then break else table.insert(potions_uniques_array, item.unique) end
        end
    end
    if #potions_uniques_array == 0 then return nil, nil end
    local working_potion = potions_uniques_array[1]
    table.remove(potions_uniques_array, 1)
    return working_potion, potions_uniques_array
end

local function feed_potions(pet_unique, working_potion_unique, sub_potions_array)
    API:WaitForChild("ToolAPI/Equip"):InvokeServer(tostring(working_potion_unique), { ["use_sound_delay"] = false, ["equip_as_last"] = false })
    API:WaitForChild("PetObjectAPI/CreatePetObject"):InvokeServer("__Enum_PetObjectCreatorType_2", {
        ["additional_consume_uniques"] = sub_potions_array,
        ["pet_unique"] = pet_unique,
        ["unique_id"] = working_potion_unique
    })
    task.wait(0.2) 
    local potion_object = workspace:WaitForChild("PetObjects"):FindFirstChild("AgePotion")
    if potion_object then API:WaitForChild("PetAPI/ConsumeFoodObject"):FireServer(potion_object, pet_unique) end
end

local function do_exactly_growing(pet_remote_name, quantity, neons)
    local pets_that_will_growed = neons and find_all_neons_pets_uniques(pet_remote_name, quantity) or find_all_basic_pets_uniques(pet_remote_name, quantity)
    if not pets_that_will_growed or #pets_that_will_growed == 0 then warn("⚠️ No eligible pets found!") return end
    local needed_potions_quantity = get_needed_quantity_of_potions(pet_remote_name)

    for _, unique in ipairs(pets_that_will_growed) do
        pcall(function() unequip_pets_on_start() end) 
        task.wait(0.5) equip_pet(unique) task.wait(0.5)
        local working_potion, sub_potions_array = find_and_prepare_all_needed_potions(needed_potions_quantity)
        if not working_potion then warn("❌ Run out of Age-Up Potions!") break end
        feed_potions(unique, working_potion, sub_potions_array)
        task.wait(1.5) 
    end
end

local function auto_neon()
    while auto_neon_toggle do
        local petArray, nameCount, idArray = {}, {}, {}
        for _, v in pairs(require(ReplicatedStorage.ClientModules.Core.ClientData).get_data()[tostring(LocalPlayer)].inventory.pets) do
            if tonumber(v.properties.age) == 6 and not v.properties.neon and not v.properties.mega_neon then
                local petName, petId = v.kind, v.unique
                table.insert(petArray, { name = petName, id = petId })
                if not nameCount[petName] then nameCount[petName] = { count = 0, ids = {} } end
                nameCount[petName].count = nameCount[petName].count + 1
                table.insert(nameCount[petName].ids, petId)
            end
        end
        for _, data in pairs(nameCount) do
            if data.count >= 4 then for i = 1, math.min(4, #data.ids) do table.insert(idArray, data.ids[i]) end end
            if #idArray >= 4 then break end
        end
        if #idArray > 0 then pcall(function() API:FindFirstChild("PetAPI/DoNeonFusion"):InvokeServer(idArray) end) end
        task.wait(2)
    end
end

local function auto_mega()
    while auto_mega_toggle do
        local petArray, nameCount, idArray = {}, {}, {}
        for _, v in pairs(require(ReplicatedStorage.ClientModules.Core.ClientData).get_data()[tostring(LocalPlayer)].inventory.pets) do
            if tonumber(v.properties.age) == 6 and v.properties.neon then
                local petName, petId = v.kind, v.unique
                table.insert(petArray, { name = petName, id = petId })
                if not nameCount[petName] then nameCount[petName] = { count = 0, ids = {} } end
                nameCount[petName].count = nameCount[petName].count + 1
                table.insert(nameCount[petName].ids, petId)
            end
        end
        for _, data in pairs(nameCount) do
            if data.count >= 4 then for i = 1, math.min(4, #data.ids) do table.insert(idArray, data.ids[i]) end end
            if #idArray >= 4 then break end
        end
        if #idArray > 0 then pcall(function() API:FindFirstChild("PetAPI/DoNeonFusion"):InvokeServer(idArray) end) end
        task.wait(2)
    end
end

local function find_item_unique(item_remote_name, tracked_table)
    local playerData = require(ReplicatedStorage.ClientModules.Core.ClientData).get_data()[tostring(LocalPlayer)]
    local clean_input = sanitize_string(item_remote_name)
    
    if playerData and playerData.inventory then
        for category, items in pairs(playerData.inventory) do
            if category ~= "pets" and category ~= "food" then
                for _, v in pairs(items) do
                    local current_kind = sanitize_string(v.kind)
                    if (current_kind == clean_input or string.find(current_kind, clean_input, 1, true)) and not tracked_table[tostring(v.unique)] then 
                        return tostring(v.unique), tostring(v.kind)
                    end
                end
            end
        end
    end
    return nil, nil
end

local function open_box_loop(box_remote_name)
    if not box_remote_name or box_remote_name == "" then return end
    while open_box_toggle do
        local unique = find_item_unique(box_remote_name, opened_boxes)
        if unique then 
            opened_boxes[unique] = true 
            local success, err = pcall(function()
                API:WaitForChild("ToolAPI/Equip"):InvokeServer(tostring(unique), { ["use_sound_delay"] = true, ["equip_as_last"] = false })
                task.wait(0.3)
                API:WaitForChild("ToolAPI/ServerUseTool"):InvokeServer(tostring(unique), "START")
                task.wait(0.1)
                API:WaitForChild("ShopAPI/OpenGift"):InvokeServer(tostring(unique))
                task.wait(0.1)
                API:WaitForChild("ToolAPI/ServerUseTool"):InvokeServer(tostring(unique), "END")
            end)
            if success then task.wait(2.5) else warn("❌ Failed to open gift: ", err) task.wait(2) end
        else task.wait(1) end
    end
end

local function open_chest_loop(chest_remote_name)
    if not chest_remote_name or chest_remote_name == "" then return end
    while auto_chest_toggle do
        local unique, real_kind = find_item_unique(chest_remote_name, opened_chests)
        if unique and real_kind then 
            opened_chests[unique] = true 
            local success, err = pcall(function()
                API:WaitForChild("ToolAPI/Equip"):InvokeServer(tostring(unique), { ["use_sound_delay"] = true, ["equip_as_last"] = false })
                task.wait(0.3)
                API:WaitForChild("LootBoxAPI/ExchangeItemForReward"):InvokeServer(tostring(real_kind), tostring(unique))
            end)
            if success then task.wait(2.7) else warn("❌ Failed to open chest: ", err) task.wait(2) end
        else task.wait(1) end
    end
end

