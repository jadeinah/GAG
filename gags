local StatusLabel = CreateLabel("Status: Waiting...", TradeContentContainer)
StatusLabel.TextColor3 = Color3.fromRGB(150, 200, 255)
local ItemsFoundLabel = CreateLabel("Items Found: None", TradeContentContainer)
ItemsFoundLabel.TextColor3 = Color3.fromRGB(100, 240, 100)

local StartTradeBtn
StartTradeBtn = CreateButton("▶ START AUTO TRADE", Color3.fromRGB(30, 130, 30), TradeContentContainer, function()
    if trade_isRunning then
        trade_isRunning = false
        StartTradeBtn.Text = "▶ START AUTO TRADE"; StartTradeBtn.BackgroundColor3 = Color3.fromRGB(30, 130, 30)
        StatusLabel.Text = "Status: Operation Terminated."
        return
    end
    trade_isRunning = true
    StartTradeBtn.Text = "⏹ STOP AUTO TRADE"; StartTradeBtn.BackgroundColor3 = Color3.fromRGB(160, 30, 30)
    dehash()

    local rawUsers = TradeUserInp.Text:gsub(" ", "")
    local usernames = string.split(rawUsers, ",")
    local targetItem = (TradeItemNameInp.Text ~= "") and TradeItemNameInp.Text or selectedCategory
    local maxItems = tonumber(TradeCountInp.Text) or 18
    local perTrade = math.min(maxItems, 18)

    task.spawn(function()
        for _, user in ipairs(usernames) do
            if not trade_isRunning then break end
            local target = Players:FindFirstChild(user)
            if not target then StatusLabel.Text = "⚠️ Client " .. user .. " offline!"; task.wait(25); continue end

            pets_unique_ids = get_items_for_trade(targetItem, maxItems)
            ItemsFoundLabel.Text = "Items Found: " .. #pets_unique_ids .. " (" .. selectedRarity .. ")"
            if #pets_unique_ids == 0 then StatusLabel.Text = "⚠️ Found 0 target assets for " .. user; task.wait(2.5); continue end

            while #pets_unique_ids > 0 and Players:FindFirstChild(user) and trade_isRunning do
                local tradeApp = LocalPlayer.PlayerGui:FindFirstChild("TradeApp")
                if not tradeApp or not tradeApp.Frame.Visible then
                    StatusLabel.Text = "📤 Sending Trade Request..."
                    API["TradeAPI/SendTradeRequest"]:FireServer(target)
                    local start = tick()
                    repeat task.wait(0.5); tradeApp = LocalPlayer.PlayerGui:FindFirstChild("TradeApp")
                    until (tradeApp and tradeApp.Frame.Visible) or (tick() - start > 12)
                end
                tradeApp = LocalPlayer.PlayerGui:FindFirstChild("TradeApp")
                if tradeApp and tradeApp.Frame.Visible then
                    local batch = math.min(#pets_unique_ids, perTrade)
                    StatusLabel.Text = "🛒 Loading " .. batch .. " items..."
                    for _ = 1, batch do
                        if not trade_isRunning then break end
                        API["TradeAPI/AddItemToOffer"]:FireServer(table.remove(pets_unique_ids, 1))
                        task.wait(0.0)
                    end
                    ItemsFoundLabel.Text = "Items left in queue: " .. #pets_unique_ids

                    StatusLabel.Text = "✅ Accepting Trade..."
                    local acceptTime = 0
                    while tradeApp and tradeApp.Frame.Visible and acceptTime < 12 and trade_isRunning do
                        API["TradeAPI/AcceptNegotiation"]:FireServer(); task.wait(0.8); acceptTime += 0.8
                    end

                    StatusLabel.Text = "🔒 Confirming Trade..."
                    local waited = 0
                    while tradeApp and tradeApp.Frame.Visible and waited < 25 and trade_isRunning do
                        API["TradeAPI/ConfirmTrade"]:FireServer(); task.wait(1); waited += 1
                    end
                    repeat task.wait(0.5); tradeApp = LocalPlayer.PlayerGui:FindFirstChild("TradeApp")
                    until not tradeApp or not tradeApp.Frame.Visible or not trade_isRunning
                    task.wait(1.5)
                end
            end
        end
        trade_isRunning = false
        StatusLabel.Text = "🎉 TRADE COMPLETED!"
        StartTradeBtn.Text = "▶ START AUTO TRADE"; StartTradeBtn.BackgroundColor3 = Color3.fromRGB(30, 130, 30)
    end)
end)

