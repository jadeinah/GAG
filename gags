local function dehash()
    pcall(function()
        local Router = require(ReplicatedStorage.ClientModules.Core.RouterClient.RouterClient)
        local get_upval = debug.getupvalue or getupvalue
        for i = 1, 15 do
            local name, val = get_upval(Router.init, i)
            if type(val) == "table" and val.AddFriendAPI then
                for k, v in pairs(val) do
                    if typeof(v) == "Instance" then v.Name = k end
                end
                return
            end
        end
    end)
end

local function get_items_for_trade(targetInput, max)
    local found = {}
    local ok, ClientData = pcall(require, ReplicatedStorage.ClientModules.Core.ClientData)
    if not ok or not ClientData then return found end

    local playerData = ClientData.get_data()[LocalPlayer.Name]
    if not playerData or not playerData.inventory then return found end

    local targetLower = targetInput:lower()
    local normTarget  = sanitize_string(targetInput)
    local categories  = {"pets", "gifts", "toys"}

    for _, cat in ipairs(categories) do
        if playerData.inventory[cat] then
            for uid, data in pairs(playerData.inventory[cat]) do
                local normKind = sanitize_string(data.kind or "")
                local props    = data.properties or {}

                local nameMatch = (targetLower == cat) or (targetLower == "all")
                    or (normKind == normTarget) or (normKind:find(normTarget, 1, true) ~= nil)
                    or (normTarget:find(normKind, 1, true) ~= nil) or (uid == targetInput)

                if nameMatch then
                    local isMega   = props.mega_neon == true
                    local isNeon   = props.neon == true and not isMega
                    local isNormal = not props.neon and not props.mega_neon

                    local rarityMatch = (selectedRarity == "ALL") or (selectedRarity == "Normal" and isNormal)
                                     or (selectedRarity == "Neon" and isNeon) or (selectedRarity == "Mega" and isMega)

                    if rarityMatch then
                        table.insert(found, data.unique or uid)
                        if #found >= max then return found end
                    end
                end
            end
        end
    end
    return found
end

